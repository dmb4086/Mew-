# Postgres / Supabase connection string used by the analytics service.
# Example (Supabase): postgresql://postgres:[PASSWORD]@db.[REF].supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ffdraft

# Optional: cap nflverse seasons to ingest (comma-separated). Default in code.
# FFDRAFT_SEASONS=2019,2020,2021,2022,2023,2024
